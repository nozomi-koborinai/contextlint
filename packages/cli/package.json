{
  "name": "@contextlint/cli",
  "version": "0.0.0",
  "description": "CLI entry point for contextlint",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "contextlint": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@contextlint/core": "workspace:*",
    "commander": "^14.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
