{
  "name": "@contextlint/cli",
  "version": "0.0.0",
  "description": "CLI entry point for contextlint",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "contextlint": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@contextlint/core": "workspace:*",
    "@contextlint/preset-dna": "workspace:*",
    "commander": "^14.0.0",
    "glob": "^13.0.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
