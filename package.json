{
  "name": "contextlint",
  "private": true,
  "description": "Rule-based linter for structured Markdown documents",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "lint": "eslint .",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "markdownlint-cli2": "^0.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
